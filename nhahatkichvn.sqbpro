-- CẬP NHẬT SUẤT DIỄN ĐÃ QUÁ KHỨ (status = 'cancelled')
-- ============================================

-- Vở 7: Ngũ hổ tướng - Đã diễn tháng 1,2/2026 (giữ nguyên)
-- Không cần update

-- Vở 11: Nghêu, Sò, Ốc, Hến - Đã diễn tháng 1,2,3/2026 (giữ nguyên)
-- Không cần update

-- Vở 3: Quan thanh tra - Cập nhật các suất đã diễn
UPDATE plays SET status = 'cancelled' 
WHERE performance_id = 3 AND start_time &lt; '2026-04-02';

-- Vở 5: Mặc cha sự đời - Cập nhật các suất đã diễn
UPDATE plays SET status = 'cancelled' 
WHERE performance_id = 5 AND start_time &lt; '2026-04-02';

-- Vở 9: Thiên mệnh - Cập nhật các suất đã diễn
