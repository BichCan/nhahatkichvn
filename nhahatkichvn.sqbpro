WHERE performance_id = 2 AND start_time &lt; '2026-04-02';

-- Vở 8: Đêm trắng - Cập nhật các suất đã diễn
UPDATE plays SET status = 'cancelled' 
WHERE performance_id = 8 AND start_time &lt; '2026-04-02';

